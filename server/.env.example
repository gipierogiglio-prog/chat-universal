# PostgreSQL connection (docker-compose db service)
DATABASE_URL="postgresql://chat:chat@localhost:5433/chat_universal?schema=public"

# Secret used to sign JWT tokens — change in production!
JWT_SECRET="change-me-to-a-long-random-string"

# Port the API + WebSocket server listens on
PORT=3001

# Allowed CORS origin for the frontend (dev). In production the server
# serves the built frontend itself, so this is only needed in dev.
CORS_ORIGIN="http://localhost:5173"

# API keys the integrations must send in the `x-api-key` header
HERMES_API_KEY="hermes-secret-key"
HERMES_WEBHOOK_URL="" # URL do Hermes Agent para encaminhamento bidirecional
OPENCLAW_API_KEY="openclaw-secret-key"

# Directory where uploaded files are stored
UPLOAD_DIR="uploads"
